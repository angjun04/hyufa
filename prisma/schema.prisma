generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String  @id @default(cuid())
  username    String  @unique
  password    String
  phoneNumber String  @unique

  gameName   String
  tagLine    String
  puuid      String  @unique
  summonerId String?

  // S15 (2025) peak — fow.kr 크롤 결과 영구 보관
  peakTierS15   String?
  peakRankS15   String?
  peakSourceS15 String? // "fow" | "manual"

  // S16 (2026) peak — 어드민이 정한 마감 시점에 lock
  peakTierS16Locked String?
  peakRankS16Locked String?
  peakLPS16Locked   Int?
  peakLockedAt      DateTime?

  preferredPositions String[] @default([])
  bio                String?
  isLookingForTeam   Boolean  @default(false)
  isAdmin            Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teamPosts        TeamPost[]
  sentContacts     ContactRequest[] @relation("SentContacts")
  receivedContacts ContactRequest[] @relation("ReceivedContacts")
  messages         Message[]

  @@unique([gameName, tagLine])
}

// PUUID 단위 티어 캐시. 회원/비회원 모두 사용.
model TierCache {
  puuid    String @id
  gameName String
  tagLine  String

  currentTier String?
  currentRank String?
  currentLP   Int?

  // 시즌 진행 중 누적 max — lock 시 User로 복사
  peakTierS16 String?
  peakRankS16 String?
  peakLPS16   Int?

  refreshedAt DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([gameName, tagLine])
}

model AppSetting {
  key   String @id
  value String
}

model TeamPost {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String
  positions   String[] @default([])
  maxTier     String?
  minTier     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contacts ContactRequest[]
}

model ContactRequest {
  id         String    @id @default(cuid())
  fromUserId String
  fromUser   User      @relation("SentContacts", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User      @relation("ReceivedContacts", fields: [toUserId], references: [id], onDelete: Cascade)
  teamPostId String?
  teamPost   TeamPost? @relation(fields: [teamPostId], references: [id], onDelete: SetNull)
  type       String
  status     String    @default("pending")
  createdAt  DateTime  @default(now())

  messages Message[]
}

model Message {
  id        String         @id @default(cuid())
  contactId String
  contact   ContactRequest @relation(fields: [contactId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User           @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime       @default(now())
}
